# Git LFS for Unreal binary content - set this up before you add any
# real Content/ assets, not after. Migrating history later is painful.
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text
*.upk filter=lfs diff=lfs merge=lfs -text
*.udk filter=lfs diff=lfs merge=lfs -text

# Common source-asset binaries (art/audio source, not engine-native but
# frequently kept alongside content)
*.fbx filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.exr filter=lfs diff=lfs merge=lfs -text

# Keep source/code as normal text diffs
*.cpp text
*.h text
*.cs text
*.ini text
